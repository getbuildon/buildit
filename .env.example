# Supabase (publishable / anon key — no uses la secret key en el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Redirect URLs en Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: http://localhost:3000 (dev) o https://tu-app.vercel.app (prod)
# - Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://tu-app.vercel.app/auth/callback
#
# En Vercel: agregá las variables y luego Redeploy (Settings → Environment Variables).
