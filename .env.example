# Supabase (publishable / anon key — no uses la secret key en el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Redirect URLs en Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: http://localhost:3000 (o tu dominio de producción)
# - Redirect URLs: http://localhost:3000/auth/callback

# Sin las variables de arriba, la app usa auth demo:
# demo@built-it.com / demo123456
